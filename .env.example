# Copy to `.env.local` and fill in. Never commit real secrets.

# --- Tally webhook (`/api/tally-webhook`) ---
TALLY_WEBHOOK_SECRET=

# Fallback contractor when Redis has no match for the lead ZIP (required)
CONTRACTOR_FALLBACK_EMAIL=
CONTRACTOR_FALLBACK_PHONE_E164=

PINATA_JWT=
ANTHROPIC_API_KEY=
CROSSMINT_API_KEY=
CROSSMINT_PROJECT_ID=
# --- Resend (transactional email) ---
# API key: https://resend.com/api-keys (use a real `re_...` secret; never commit it).
RESEND_API_KEY=
#
# Production: add and verify your domain in the Resend dashboard, then set RESEND_FROM to an address on that domain
# (e.g. leads@yourdomain.com). `onboarding@resend.dev` is for quick local/testing only and is not suitable for production.
RESEND_FROM=onboarding@resend.dev
#
# Alerts when a lead needs manual routing (insufficient USDC, transfer awaiting approval).
ADMIN_EMAIL=
LEAD_FEE_USDC=
TREASURY_WALLET_ADDRESS=

# Optional
# CROSSMINT_API_BASE=
# CROSSMINT_CHAIN=base
# ANTHROPIC_MODEL=
# CROSSMINT_TRANSFER_SIGNER=
# REDIS_URL=
# TALLY_ZIP_FIELD_LABEL=Zip/Postal Code
# TALLY_ZIP_FIELD_KEY=

# --- Redis ZIP seed script (`yarn seed:zips`) ---
# CONTRACTOR_SEED_EMAIL=
# CONTRACTOR_SEED_PHONE_E164=
# CONTRACTOR_SEED_NAME=
