# Copy to `.env.local` and fill in. Never commit real secrets.

# Canonical URL for Open Graph / metadata (`metadataBase`). Optional: Vercel Production falls back to
# https://www.staugustinepressurewashingpros.com when unset. Set locally if you need a different base (e.g. preview).
# NEXT_PUBLIC_SITE_URL=https://www.staugustinepressurewashingpros.com

# --- Tally webhook: Pressure Washing Interest Form → POST your app URL + `/api/tally-webhook`
# Example: `https://<project>.vercel.app/api/tally-webhook` (or your custom domain).
# In Tally: Form settings → Webhooks → same secret as `TALLY_WEBHOOK_SECRET` (signing secret from Tally).
TALLY_WEBHOOK_SECRET=

# Lead ZIP routing: default label `Zip/Postal Code` matches the consumer form. For duplicate labels
# elsewhere in the form, prefer setting a stable field `key` from Tally’s “Test webhook” / payload log:
# TALLY_ZIP_FIELD_KEY=question_xxxx
# TALLY_ZIP_FIELD_LABEL=Zip/Postal Code

# Optional: stable Tally `key` values for the Pressure Washing lead form (from one sample `FORM_RESPONSE`).
# Reduces reliance on labels; set after submitting a test response and copying `data.fields[].key`.
# TALLY_LEAD_FIRST_NAME_KEY=
# TALLY_LEAD_LAST_NAME_KEY=
# TALLY_LEAD_PHONE_KEY=
# TALLY_LEAD_EMAIL_KEY=
# TALLY_LEAD_PROPERTY_TYPE_KEY=
# TALLY_LEAD_STREET_ADDRESS_KEY=
# TALLY_LEAD_APARTMENT_KEY=
# TALLY_LEAD_CITY_KEY=
# TALLY_LEAD_STATE_KEY=
# TALLY_LEAD_ZIP_KEY=
# TALLY_LEAD_COUNTRY_KEY=
# TALLY_LEAD_SMS_OPT_IN_KEY=
# TALLY_LEAD_SERVICES_KEY=
# TALLY_LEAD_JOB_SIZE_KEY=
# TALLY_LEAD_SERVICE_TIMING_KEY=
# TALLY_LEAD_DIRT_LEVEL_KEY=
# TALLY_LEAD_WATER_ACCESS_KEY=
# TALLY_LEAD_SPECIAL_NOTES_KEY=

# Tally form hygiene (recommended): give the SMS opt-in checkboxes a clear label (not “Untitled…”).
# If two blocks share the same label (e.g. duplicate “What do you need cleaned?”), rename one in Tally
# or use `TALLY_LEAD_*_KEY` above — duplicate labels make label-only extraction ambiguous.

# --- Contractor onboarding (`/api/contractor-onboarding`) — signing secret from that form’s Tally webhook
CONTRACTOR_ONBOARDING_TALLY_WEBHOOK_SECRET=

# Vercel KV / Upstash (contractor lists `zip:<5-digit>:contractors`; lead routing reads same store)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: stable Tally field `key` values from a sample webhook (otherwise label fallbacks match the Partner form)
# TALLY_CONTRACTOR_COMPANY_KEY=
# TALLY_CONTRACTOR_EMAIL_KEY=
# TALLY_CONTRACTOR_PHONE_KEY=
# TALLY_CONTRACTOR_ZIPS_KEY=
# TALLY_CONTRACTOR_WALLET_KEY=
# TALLY_CONTRACTOR_FIRST_NAME_KEY=
# TALLY_CONTRACTOR_LAST_NAME_KEY=
# TALLY_CONTRACTOR_JOB_TITLE_KEY=
# TALLY_CONTRACTOR_COUNTRY_KEY=

# Fallback contractor when Redis has no match for the lead ZIP (required)
CONTRACTOR_FALLBACK_EMAIL=
CONTRACTOR_FALLBACK_PHONE_E164=

PINATA_JWT=
# Optional: enables AI-generated emails via Claude. When absent, template-based emails are used instead.
# ANTHROPIC_API_KEY=
CROSSMINT_API_KEY=
CROSSMINT_PROJECT_ID=
# --- Resend (transactional email) ---
# API key: https://resend.com/api-keys (use a real `re_...` secret; never commit it).
RESEND_API_KEY=
#
# Production: add and verify your domain in the Resend dashboard, then set RESEND_FROM to an address on that domain
# (e.g. leads@yourdomain.com). `onboarding@resend.dev` is for quick local/testing only and is not suitable for production.
RESEND_FROM=onboarding@resend.dev
#
# Alerts when a lead needs manual routing (insufficient USDC, transfer awaiting approval).
ADMIN_EMAIL=
LEAD_FEE_USDC=
TREASURY_WALLET_ADDRESS=

# Optional
# CROSSMINT_API_BASE=
# CROSSMINT_CHAIN=base
# ANTHROPIC_MODEL=
# CROSSMINT_TRANSFER_SIGNER=

# Redis: contractor ZIP keys (`contractor:zip:<5>`), lead daily counters (`lead:count:*`), contractor pause (`contractor:paused:<email>`)
REDIS_URL=

# --- Internal ops API (Pinata Agent / scripts): GET /api/admin/lead-stats, POST /api/admin/contractor-pause ---
# Authorization: Bearer <ADMIN_API_SECRET>. Requires REDIS_URL.
# On Vercel: after adding or changing this value, redeploy the project so the running deployment picks it up.
# The header must use the literal prefix "Bearer " (capital B); the token must match this value exactly (trimmed).
ADMIN_API_SECRET=

# --- Redis ZIP seed script (`yarn seed:zips`) ---
# CONTRACTOR_SEED_EMAIL=
# CONTRACTOR_SEED_PHONE_E164=
# CONTRACTOR_SEED_NAME=
